//@version=5
indicator("Dual-MA Trend Filter Dashboard (MA50 & MA200)", overlay=true)

// 1. Calculate Core Indicators: MA50 & MA200
ma50 = ta.sma(close, 50)
ma200 = ta.sma(close, 200)

// 2. Plot Moving Averages (MA50: Dashed Blue, MA200: Solid Thick Red)
plot(ma50, color=color.blue, style=plot.style_line, title="MA50 (Mid-term)")
plot(ma200, color=color.red, linewidth=2, title="MA200 (Long-term)")

// 3. Calculate Percentage Deviations
dev50 = ((close - ma50) / ma50) * 100
dev200 = ((close - ma200) / ma200) * 100

// 4. Construct Institutional-Grade Multi-Quadrant UI Table
var table infoTable = table.new(position.top_right, 2, 5, border_width = 1)

if barstate.islast
    // Table Header Setup
    table.cell(infoTable, 0, 0, "Quant Metric", bgcolor=color.black, text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "Live Market Data", bgcolor=color.black, text_color=color.white, text_size=size.small)
    
    // Row 1: Latest Closing Price
    table.cell(infoTable, 0, 1, "Latest Close", bgcolor=color.new(color.gray, 90), text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(close, "#.##"), bgcolor=color.new(color.gray, 90), text_size=size.small)
    
    // Row 2: MA50 Level and Deviation
    table.cell(infoTable, 0, 2, "MA50 (Dev %)", bgcolor=color.new(color.gray, 90), text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(ma50, "#.##") + " (" + str.tostring(dev50, "#.##") + "%)", bgcolor=color.new(color.gray, 90), text_size=size.small)
    
    // Row 3: MA200 Level and Deviation
    table.cell(infoTable, 0, 3, "MA200 (Dev %)", bgcolor=color.new(color.gray, 90), text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(ma200, "#.##") + " (" + str.tostring(dev200, "#.##") + "%)", bgcolor=color.new(color.gray, 90), text_size=size.small)
    
    // Row 4: Dynamic 3-Quadrant Strategy Logic & Color-Coding
    color statusBgColor = color.new(color.gray, 90)
    string statusText = ""
    
    if (close < ma50 and close > ma200)
        statusBgColor := color.new(color.green, 60) // Bull Market Retracement (High Risk-Reward)
        statusText := "🚨 Buy Setup (Bull Backtest)"
    else if (close < ma200)
        statusBgColor := color.new(color.orange, 50) // Structural Bear Market (Defensive DCA)
        statusText := "💥 Risk Warning (Deep Bear)"
    else
        statusBgColor := color.new(color.blue, 80) // Standard Bullish Momentum
        statusText := "✅ Strong Trend (Bull Run)"
        
    table.cell(infoTable, 0, 4, "Macro Strategy Status", bgcolor=statusBgColor, text_size=size.small)
    table.cell(infoTable, 1, 4, statusText, bgcolor=statusBgColor, text_size=size.small)
